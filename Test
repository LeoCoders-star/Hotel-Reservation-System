import java.util.Scanner;
import java.util.ArrayList; 

public class Main {
    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);

        // Di sini kita simpan semua customer yang dah buat booking
        ArrayList<Customer> customerList = new ArrayList<>();

        Room roomObj = new Room();
        Reservation reservationObj = new Reservation();
        Payment paymentObj = new Payment();

        Administrator adminAkaun = new Administrator("2007", "Afiq Leo", "0123456789", "admin123", "passadmin", "A01", "Manager");

        boolean running = true;
        while (running) {
            System.out.println("\n=================================");
            System.out.println(" WELCOME TO THE HOTEL RESERVATION ");
            System.out.println("=================================");
            System.out.println("1. Admin Panel");
            System.out.println("2. Customer Service (Guest)");
            System.out.println("3. Exit");
            System.out.print("Please choose your identity to start: ");
            int identity = input.nextInt();
            input.nextLine(); // Clear buffer

            if (identity == 1) {
                System.out.println("\n--- ADMIN LOGIN ---");
                System.out.print("Please enter Admin ID: ");
                String inputAdminID = input.nextLine();
                System.out.print("Please enter Password: ");
                String inputPassword = input.nextLine();

                if (inputAdminID.equals(adminAkaun.getAdminID()) && adminAkaun.login(adminAkaun.getUsername(), inputPassword)) {
                    System.out.println("\nLogin Successful! Welcome Back, " + adminAkaun.getName());
                    
                    // PASSED: customerList dihantar ke adminMenu
                    adminMenu(input, adminAkaun, reservationObj, roomObj, customerList); 
                } else {
                    System.out.println("\n[Error] Invalid Admin ID or Password!");
                }

            } else if (identity == 2) {
                // PASSED: customerList dihantar ke customerMenu supaya bila booking, data masuk sini
                customerMenu(input, roomObj, reservationObj, paymentObj, customerList); 
            } else if (identity == 3) {
                System.out.println("\nThank you!");
                running = false;
            }
        }
        input.close();
    }

    public static void adminMenu(Scanner input, Administrator admin, Reservation reservationObj, Room roomObj, ArrayList<Customer> customerList) {
        boolean menuNum = true;

        while (menuNum) {
            System.out.print("\n=== ADMIN MENU SECTION ===");
            System.out.print("\n1. Manage Rooms");
            System.out.print("\n2. View All Customers & Booking IDs (Total: " + customerList.size() + ")");
            System.out.print("\n3. View History Booking (By Reservation)");
            System.out.print("\n4. Cancel Booking");
            System.out.print("\n5. LogOut\n");

            System.out.print("\nSelect an option: ");
            int menuOption = input.nextInt();
            input.nextLine(); 

            switch (menuOption) {
                case 1:
                    admin.manageRooms(roomObj); 
                    break;
                case 2:
                    // LOGIK ADMIN: Melihat siapa yang dah booking
                    System.out.println("\n--- LIST OF CUSTOMERS WHO BOOKED ---");
                    if (customerList.isEmpty()) {
                        System.out.println("No customers have booked yet.");
                    } else {
                        for (int i = 0; i < customerList.size(); i++) {
                            Customer c = customerList.get(i);
                            // Pastikan kelas Customer ada method getName() dan getBookingID()
                            System.out.println((i+1) + ". Name: " + c.getName() + " | Booking ID: " + c.getBookingID());
                        }
                    }
                    break;
                case 3:
                    admin.viewHistoryBooking(reservationObj); 
                    break;
                case 4:
                    admin.cancelBooking(reservationObj); 
                    break;
                case 5:
                    System.out.print("\nLogOut Successfully...");
                    menuNum = false;
                    break;
                default:
                    break;
            }
        }
    }

    public static void customerMenu(Scanner input, Room roomObj, Reservation reservationObj, Payment paymentObj, ArrayList<Customer> customerList) {
        boolean menuNum = true;

        while (menuNum) {
            System.out.print("\n=== CUSTOMER MENU SECTION ===");
            System.out.print("\n1. Check Room Availability");
            System.out.print("\n2. Make a New Room Reservation (Guest Booking)");
            System.out.print("\n3. View My Booking History");
            System.out.print("\n4. Back to Main Menu\n");

            System.out.print("Select an option: ");
            int menuOption = input.nextInt();
            input.nextLine(); 

            switch (menuOption) {
                case 1:
                    System.out.println("Room availability status: " + roomObj.checkAvailability());
                    break;
                
                case 2:
                    // Minta data customer terus di sini (Guest Checkout Style)
                    System.out.println("\n--- GUEST BOOKING ---");
                    System.out.print("Enter Your Name: ");
                    String name = input.nextLine();
                    System.out.print("Enter Your Phone Number: ");
                    String phone = input.nextLine();
                    
                    // Generate ID secara automatik (Contoh mudah guna format masa/random)
                    String generatedBookingID = "BK" + (customerList.size() + 101); 
                    
                    // Cipta objek customer baru berdasarkan input tadi
                    Customer newCustomer = new Customer(name, phone, generatedBookingID);
                    
                    // SIMPAN ke dalam ArrayList utama
                    customerList.add(newCustomer);
                    
                    // Teruskan proses reservation bilik
                    reservationObj.makeReservation(); 
                    
                    System.out.println("\n[Success] Booking successful!");
                    System.out.println("IMPORTANT: Please save your Booking ID -> ** " + generatedBookingID + " **");
                    break;
                
                case 3:
                    System.out.print("Please enter your Booking ID: ");
                    String searchBookingID = input.nextLine();
                    reservationObj.viewBookingByID(searchBookingID); 
                    break;

                case 4:
                    menuNum = false;
                    break;

                default:
                    break;
            }
        }
    }
}